✅ 10. Grade System for Multiple Subjects (Different Logic)
public class ResultStatus {
    public static void main(String[] args) {
        int[] marks = {50, 60, 30, 80, 90};
        boolean fail = false;

        for (int m : marks) {
            if (m < 40) {
                fail = true;
                break;
            }
        }

        if (fail)
            System.out.println("Result = FAIL");
        else
            System.out.println("Result = PASS");
    }
}
