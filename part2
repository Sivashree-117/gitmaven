✅ 4. Library Book Management System
📌 Logic
Check if book is available
Issue book → mark unavailable
Return book → mark available
💻 Code
public class LibrarySystem {
    public static void main(String[] args) {

        boolean bookAvailable = true;

        // Issue book
        if (bookAvailable) {
            System.out.println("Book Issued");
            bookAvailable = false;
        } else {
            System.out.println("Book Not Available");
        }

        // Return book
        bookAvailable = true;
        System.out.println("Book Returned");

        // Status
        System.out.println("Available Now: " + bookAvailable);
    }
}
✅ 5. Simple Calculator Application
📌 Logic
Perform +, -, *, / using operator
💻 Code
public class Calculator {
    public static void main(String[] args) {

        int a = 10, b = 5;
        char op = '+';  // change operator

        switch (op) {
            case '+':
                System.out.println("Result = " + (a + b));
                break;
            case '-':
                System.out.println("Result = " + (a - b));
                break;
            case '*':
                System.out.println("Result = " + (a * b));
                break;
            case '/':
                System.out.println("Result = " + (a / b));
                break;
            default:
                System.out.println("Invalid Operator");
        }
    }
}
